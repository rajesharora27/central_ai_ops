generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum ArtifactType {
  RULE
  SKILL
  WORKFLOW
  COMMAND
  ENVIRONMENT_WRAPPER
}

enum AIEnvironment {
  CLAUDE
  CODEX
  CURSOR
  OPENCODE
  AGENTS
  ALL
}

enum ComplianceStatus {
  COMPLIANT
  DRIFTED
  NON_COMPLIANT
  UNKNOWN
  PENDING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VERIFY
  SYNC
  APPLY
}

model GovernanceArtifact {
  id           String          @id @default(cuid())
  name         String
  displayName  String
  type         ArtifactType
  description  String?
  filePath     String          @unique
  contentHash  String
  environments AIEnvironment[]
  isActive     Boolean         @default(true)
  version      Int             @default(1)
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  assignments ProjectArtifactAssignment[]
  auditLogs   GovernanceAuditLog[]

  @@index([type])
  @@index([isActive])
  @@index([name])
}

model Project {
  id               String           @id @default(cuid())
  name             String           @unique
  slug             String           @unique
  repoPath         String?
  repoUrl          String?
  description      String?
  isActive         Boolean          @default(true)
  lastVerifiedAt   DateTime?
  complianceStatus ComplianceStatus @default(UNKNOWN)
  complianceScore  Int?
  apiKey           String?          @unique
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  assignments      ProjectArtifactAssignment[]
  complianceChecks ComplianceCheck[]
  auditLogs        GovernanceAuditLog[]

  @@index([complianceStatus])
  @@index([slug])
}

model ProjectArtifactAssignment {
  id             String          @id @default(cuid())
  projectId      String
  artifactId     String
  environments   AIEnvironment[]
  isRequired     Boolean         @default(true)
  overridePolicy String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  project  Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact GovernanceArtifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([projectId, artifactId])
  @@index([projectId])
  @@index([artifactId])
}

model ComplianceCheck {
  id          String           @id @default(cuid())
  projectId   String
  status      ComplianceStatus
  score       Int?
  summary     String?
  details     Json?
  triggeredBy String?
  duration    Int?
  createdAt   DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@index([status])
}

model GovernanceAuditLog {
  id         String       @id @default(cuid())
  action     AuditAction
  userId     String?
  artifactId String?
  projectId  String?
  details    Json?
  createdAt  DateTime     @default(now())

  artifact GovernanceArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  project  Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([artifactId])
  @@index([projectId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
